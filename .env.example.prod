# Supplier API (untuk verifikasi seller)
# Public endpoint default:
# - /api/suppliers/public/check/
# - /api/suppliers/public/products/{supplier_id}/
SUPPLIER_API_URL=https://<your-ngrok-domain>.ngrok-free.app/
SUPPLIER_CHECK_PATH=/api/suppliers/public/check/
SUPPLIER_PRODUCTS_PATH=/api/suppliers/public/products/{supplier_id}/
SUPPLIER_IMPORT_DEFAULT_ID=UDY9-P3IE-MC26-O3YX
SUPPLIER_API_KEY=replace_with_random_secret_min_32_chars
ENFORCE_SUPPLIER_API_KEY=true
SUPPLIER_RATE_LIMIT_WINDOW_MS=60000
SUPPLIER_RATE_LIMIT_MAX=60


