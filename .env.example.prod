EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=noreply@kopmasshop.com
EMAIL_HOST_PASSWORD=strong_password
DEFAULT_FROM_EMAIL=Kopmasshop <noreply@kopmasshop.com>


# Media & Static
MEDIA_URL=/media/
STATIC_URL=/static/



# Google OAuth
GOOGLE_CLIENT_ID=972395070657-0g9i72vaia0i8undsp5olrdo9ukrf8c5.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

